[
  {
    "name": "TypeCheck",
    "run": "vehicle check -s spec.vcl",
    "needs": ["spec.vcl"]
  },
  {
    "name": "Agda",
    "run": "vehicle compile -s spec.vcl -t Agda -o Agda.agda",
    "needs": ["spec.vcl"],
    "produces": ["Agda.agda"]
  },
  {
    "name": "Rocq",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"]
  },
  {
    "name": "RocqVerify",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v && rocq compile -w none -vok Rocq.v",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"],
    "external": ["rocq"],
    "ignore": {"files": [".Rocq.aux", "Rocq.glob", "Rocq.vok"]}
  }
]
