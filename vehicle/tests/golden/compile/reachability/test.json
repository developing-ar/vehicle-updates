[
  {
    "name": "TypeCheck",
    "run": "vehicle check -s spec.vcl",
    "needs": ["spec.vcl"]
  },
  {
    "name": "Marabou",
    "run": "vehicle compile -s spec.vcl -t MarabouQueries -o Marabou.queries/ --network f:fake.onnx",
    "needs": ["spec.vcl", "fake.onnx"],
    "produces": ["Marabou.queries/*.txt", "Marabou.queries/reachable.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    }
  },
  {
    "name": "Agda",
    "run": "vehicle compile -s spec.vcl -t Agda -o Agda.agda -c Marabou.queries",
    "needs": ["spec.vcl"],
    "produces": ["Agda.agda"]
  },
  {
    "name": "Rocq",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"]
  },
  {
    "name": "RocqVerify",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v && coqc -vok Rocq.v -w none",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"],
    "externals": ["coqc"],
    "ignore": {"files": [".Rocq.aux", "Rocq.glob", "Rocq.vok"]}
  },
  {
    "name": "DL2Loss",
    "run": "vehicle compile -s spec.vcl -t DL2Loss -o DL2Loss.vcl",
    "needs": ["spec.vcl"],
    "produces": ["DL2Loss.vcl"],
    "enabled": false
  }
]
