@property;
p1 : (Tensor Real -> Tensor Real) -> Tensor Real;
p1 f = [ 1.0 ] / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x -> [ 1.0 ] / max 0.0 (1.0 - f x ! 0))

@property;
p2 : (Tensor Real -> Tensor Real) -> Tensor Real;
p2 g = [ 1.0, 1.0 ] / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x -> [ 1.0, 1.0 ] / max 0.0 (0.0 - g x ! 0))