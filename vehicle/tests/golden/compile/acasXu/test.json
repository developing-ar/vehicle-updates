[
  {
    "name": "TypeCheck",
    "run": "vehicle check -s spec.vcl",
    "needs": ["spec.vcl"]
  },
  {
    "name": "ListResources",
    "run": "vehicle list resources -s spec.vcl -j",
    "needs": ["spec.vcl"]
  },
  {
    "name": "ListProperties",
    "run": "vehicle list properties -s spec.vcl -j",
    "needs": ["spec.vcl"]
  },
  {
    "name": "VNNLib",
    "run": "vehicle compile -s spec.vcl -t VNNLibQueries -o VNNLib.queries --network acasXu:fake.onnx",
    "needs": ["spec.vcl", "fake.onnx"],
    "produces": ["VNNLib.queries/*.txt", "VNNLib.queries/property*.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    },
    "sizeOnly": ".vcl-plan"
  },
  {
    "name": "Marabou",
    "run": "vehicle compile -s spec.vcl -t MarabouQueries -o Marabou.queries --network acasXu:fake.onnx",
    "needs": ["spec.vcl", "fake.onnx"],
    "produces": ["Marabou.queries/*.txt", "Marabou.queries/property*.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    },
    "sizeOnly": ".vcl-plan"
  },
  {
    "name": "MarabouVerify",
    "run": "vehicle verify -s spec.vcl --verifier Marabou --network acasXu:acasXu_1_7.onnx --property property3",
    "needs": ["spec.vcl", "acasXu_1_7.onnx"],
    "external": ["Marabou"]
  },
  {
    "name": "Agda",
    "run": "vehicle compile -s spec.vcl -t Agda -o Agda.agda",
    "needs": ["spec.vcl"],
    "produces": ["Agda.agda"]
  },
  {
    "name": "Rocq",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"]
  },
  {
    "name": "RocqVerify",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v && rocq compile -w none -vok Rocq.v",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"],
    "external": ["rocq"],
    "ignore": {"files": [".Rocq.aux", "Rocq.glob", "Rocq.vok"]},
    "enabled": false
  }
]
