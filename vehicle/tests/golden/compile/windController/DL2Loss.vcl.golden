@property;
safe : (Tensor Real -> Tensor Real) -> Tensor Real;
safe controller = [ 1.0, 1.0 ] / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x -> [ 1.0, 1.0 ] / (1.0 / (- (max 0.0 (-3.25 - x ! 0) + max 0.0 (x ! 0 - -3.25)) + - (max 0.0 (x ! 0 - 3.25) + max 0.0 (3.25 - x ! 0)) + (- (max 0.0 (-3.25 - x ! 1) + max 0.0 (x ! 1 - -3.25)) + - (max 0.0 (x ! 1 - 3.25) + max 0.0 (3.25 - x ! 1)))) * (- (max 0.0 (-1.25 - (controller [(x ! 0 + 4.0) / 8.0, (x ! 1 + 4.0) / 8.0] ! 0 + 2.0 * x ! 0 - x ! 1)) + max 0.0 (controller [(x ! 0 + 4.0) / 8.0, (x ! 1 + 4.0) / 8.0] ! 0 + 2.0 * x ! 0 - x ! 1 - -1.25)) + - (max 0.0 (controller [(x ! 0 + 4.0) / 8.0, (x ! 1 + 4.0) / 8.0] ! 0 + 2.0 * x ! 0 - x ! 1 - 1.25) + max 0.0 (1.25 - (controller [(x ! 0 + 4.0) / 8.0, (x ! 1 + 4.0) / 8.0] ! 0 + 2.0 * x ! 0 - x ! 1))))))