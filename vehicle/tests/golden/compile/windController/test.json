[
  {
    "name": "TypeCheck",
    "run": "vehicle check -s spec.vcl",
    "needs": ["spec.vcl"]
  },
  {
    "name": "ListResources",
    "run": "vehicle list resources -s spec.vcl -j",
    "needs": ["spec.vcl"]
  },
  {
    "name": "ListProperties",
    "run": "vehicle list properties -s spec.vcl -j",
    "needs": ["spec.vcl"]
  },
  {
    "name": "VNNLib",
    "run": "vehicle compile -s spec.vcl -t VNNLibQueries -o VNNLib.queries/ --network controller:controller.onnx",
    "needs": ["spec.vcl", "controller.onnx"],
    "produces": ["VNNLib.queries/*.txt", "VNNLib.queries/*.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    },
    "sizeOnly": ".vcl-plan"
  },
  {
    "name": "Marabou",
    "run": "vehicle compile -s spec.vcl -t MarabouQueries -o Marabou.queries/ --network controller:controller.onnx",
    "needs": ["spec.vcl", "controller.onnx"],
    "produces": ["Marabou.queries/*.txt", "Marabou.queries/*.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    },
    "sizeOnly": ".vcl-plan"
  },
  {
    "name": "Agda",
    "run": "vehicle compile -s spec.vcl -t Agda -o Agda.agda",
    "needs": ["spec.vcl"],
    "produces": ["Agda.agda"]
  },
  {
    "name": "Rocq",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"]
  },
  {
    "name": "RocqVerify",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v && rocq compile -w none -vok Rocq.v",
    "needs": ["spec.vcl"],
    "external": ["rocq"],
    "ignore": {"files": ["Rocq.v", ".Rocq.aux", "Rocq.glob", "Rocq.vok"]}
  },
  {
    "name": "DL2Loss",
    "run": "vehicle compile -s spec.vcl -t DL2Loss -o DL2Loss.vcl --network controller:controller.onnx ",
    "needs": ["spec.vcl"],
    "produces": ["DL2Loss.vcl"]
  },
  {
    "name": "MarabouVerify",
    "run": "vehicle verify -s spec.vcl -v Marabou --network controller:controller.onnx",
    "needs": ["spec.vcl", "controller.onnx"],
    "external": ["Marabou"]
  },
  {
    "name": "TestVerify",
    "run": "vehicle verify -s spec.vcl -v TestVerifier --network controller:controller.onnx --verifier-location=testVerifier --verifier-args='sat 'controller_X[0]=0.2,controller_X[1]=0.3,controller_Y[0]=3.0''",
    "needs": ["spec.vcl", "controller.onnx", "../../../testVerifier"],
    "external": ["TestVerifier"]
  },
  {
    "name": "TestVerifyJSON",
    "run": "vehicle --json verify -s spec.vcl -v TestVerifier --network controller:controller.onnx --verifier-location=testVerifier --verifier-args='sat 'controller_X[0]=0.2,controller_X[1]=0.3,controller_Y[0]=3.0''",
    "needs": ["spec.vcl", "controller.onnx", "../../../testVerifier"],
    "external": ["TestVerifier"]
  }
]
