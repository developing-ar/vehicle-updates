@property;
andGateCorrect : (Tensor Real -> Tensor Real) -> Tensor Real;
andGateCorrect andGate = 1.0 / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x1 -> 1.0 / (1.0 / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x2 -> 1.0 / (1.0 / (- (max 0.0 (0.0 - x1) + max 0.0 x1) + - (max 0.0 (x1 - 1.0) + max 0.0 (1.0 - x1)) + (- (max 0.0 (0.0 - x2) + max 0.0 x2) + - (max 0.0 (x2 - 1.0) + max 0.0 (1.0 - x2)))) * (1.0 / (- (max 0.0 (x1 - 0.5) + max 0.0 (0.5 - x1)) + - (max 0.0 (x2 - 0.5) + max 0.0 (0.5 - x2))) * - (max 0.0 (andGate [x1, x2] ! 0 - 0.5) + max 0.0 (0.5 - andGate [x1, x2] ! 0)) + (1.0 / (- (max 0.0 (x1 - 0.5) + max 0.0 (0.5 - x1)) + - (max 0.0 (x2 - 0.5) + max 0.0 (0.5 - x2))) * - (max 0.0 (andGate [x1, x2] ! 0 - 0.5) + max 0.0 (0.5 - andGate [x1, x2] ! 0)) + (1.0 / (- (max 0.0 (x1 - 0.5) + max 0.0 (0.5 - x1)) + - (max 0.0 (x2 - 0.5) + max 0.0 (0.5 - x2))) * - (max 0.0 (andGate [x1, x2] ! 0 - 0.5) + max 0.0 (0.5 - andGate [x1, x2] ! 0)) + 1.0 / (- (max 0.0 (x1 - 0.5) + max 0.0 (0.5 - x1)) + - (max 0.0 (x2 - 0.5) + max 0.0 (0.5 - x2))) * - (max 0.0 (andGate [x1, x2] ! 0 - 0.5) + max 0.0 (0.5 - andGate [x1, x2] ! 0)))))))))