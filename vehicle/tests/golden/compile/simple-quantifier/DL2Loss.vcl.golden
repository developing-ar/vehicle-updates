@property;
expandedExpr : (Tensor Real -> Tensor Real) -> Tensor Real;
expandedExpr f = [ 1.0 ] / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x -> [ 1.0 ] / - (max 0.0 (x ! 0 - f x ! 0) + max 0.0 (f x ! 0 - x ! 0)))

@property;
parallel : (Tensor Real -> Tensor Real) -> Tensor Real;
parallel f = [ 1.0 ] / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x -> [ 1.0 ] / - (max 0.0 (f x ! 0) + max 0.0 (0.0 - f x ! 0))) + search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x -> - (max 0.0 (f x ! 0 - 5.0) + max 0.0 (5.0 - f x ! 0)))