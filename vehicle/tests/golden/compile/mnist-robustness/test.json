[
  {
    "name": "TypeCheck",
    "run": "vehicle check -s spec.vcl",
    "needs": ["spec.vcl"]
  },
  {
    "name": "List",
    "run": "vehicle list -s spec.vcl -j",
    "needs": ["spec.vcl"]
  },
  {
    "name": "VNNLib",
    "run": "vehicle compile -s spec.vcl -t VNNLibQueries -o VNNLib.queries/ --network classifier:fake.onnx --parameter epsilon:0.1 --dataset trainingImages:images.idx --dataset trainingLabels:labels.idx",
    "needs": ["spec.vcl", "fake.onnx", "images.idx", "labels.idx"],
    "produces": ["VNNLib.queries/*.txt", "VNNLib.queries/robust*.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    }
  },
  {
    "name": "Marabou",
    "run": "vehicle compile -s spec.vcl -t MarabouQueries -o Marabou.queries/ --network classifier:fake.onnx --parameter epsilon:0.1 --dataset trainingImages:images.idx --dataset trainingLabels:labels.idx",
    "needs": ["spec.vcl", "fake.onnx", "images.idx", "labels.idx"],
    "produces": ["Marabou.queries/*.txt", "Marabou.queries/robust*.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    }
  },
  {
    "name": "Agda",
    "run": "vehicle compile -s spec.vcl -t Agda -o Agda.agda",
    "needs": ["spec.vcl"],
    "produces": ["Agda.agda"]
  },
  {
    "name": "Rocq",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v",
    "needs": ["spec.vcl"],
    "produces": ["Rocq.v"],
    "enabled": false
  },
  {
    "name": "RocqVerify",
    "run": "vehicle compile -s spec.vcl -t Rocq -o Rocq.v && rocq compile -w none -vok Rocq.v",
    "needs": ["spec.vcl"],
    "external": ["rocq"],
    "ignore": {"files": ["Rocq.v", ".Rocq.aux", "Rocq.glob", "Rocq.vok"]},
    "enabled": false
  },
  {
    "name": "DL2Loss",
    "run": "vehicle compile -s spec.vcl -t DL2Loss -o DL2Loss.vcl",
    "needs": ["spec.vcl"],
    "produces": ["DL2Loss.vcl"],
    "enabled": false
  },
  {
    "name": "VehicleLoss",
    "run": "vehicle compile -s spec.vcl -t VehicleLoss -o VehicleLoss.vcl",
    "needs": ["spec.vcl"],
    "produces": ["VehicleLoss.vcl"],
    "enabled": false
  }
]
