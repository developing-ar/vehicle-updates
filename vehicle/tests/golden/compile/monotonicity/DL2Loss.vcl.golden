@property;
monotonic : (Tensor Real -> Tensor Real) -> Tensor Real;
monotonic f = 1.0 / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x1 -> 1.0 / (1.0 / search (\ e -> \ xs -> reduceMul e xs) 0.0 0.0 (\ x2 -> 1.0 / (1.0 / - (max 0.0 (x1 - x2) + max 0.0 (x2 - x1)) * reduceAdd 0.0 (- (max [ 0.0 ] (f [x1] - f [x2]) + max [ 0.0 ] (f [x2] - f [x1])))))))