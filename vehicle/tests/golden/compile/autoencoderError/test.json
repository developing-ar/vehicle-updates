[
  {
    "name": "TypeCheck",
    "run": "vehicle check -s spec.vcl",
    "needs": ["spec.vcl"]
  },
  {
    "name": "VNNLib",
    "run": "vehicle compile -s spec.vcl -t VNNLibQueries -o VNNLib.queries/ --network encode:fake.onnx --network decode:fake.onnx",
    "needs": ["spec.vcl", "fake.onnx"],
    "produces": ["VNNLib.queries/*.txt", "VNNLib.queries/identity.vcl-plan"],
    "ignore": {
      "lines": ".*\"fileHash\".*"
    },
    "enabled":false
  },
  {
    "name": "Agda",
    "run": "vehicle compile -s spec.vcl -t Agda -o Agda.agda",
    "needs": ["spec.vcl"],
    "produces": ["Agda.agda"]
  }
]
